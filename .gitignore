__pycache__/
*.py[cod]
*$py.class

# Virtual environments
venv/
env/
ENV/
.venv/

# Environment variables - NEVER COMMIT
.env
.env.local
.env.*.local

# Database files (auto-generated)
*.db
*.sqlite
*.sqlite3

# FAISS Index Files (auto-generated, large binary)
data/faiss_index.bin
data/faiss_id_map.pkl

# Logs
logs/
*.log

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/
.mypy_cache/

# Tool configs
.cache/
.claude/

# Distribution
dist/
build/
*.egg-info/

# Jupyter Notebook
.ipynb_checkpoints/

# Streamlit
.streamlit/

# Render/Deployment
.render/

# Temporary files
tmp/
temp/
*.tmp

